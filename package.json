{
  "name": "ts-xbee-api",
  "description": "Node.js and Chrome communicate with XBee/ZigBee devices in API mode",
  "version": "3.0.0",
  "homepage": "https://github.com/flaviut/ts-xbee-api",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm run build && pnpm run type-check && pnpm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "dependencies": {
    "@serialport/parser-readline": "^10.2.2",
    "@serialport/stream": "^10.2.2",
    "real-cancellable-promise": "^1.2.0",
    "typed-emitter": "^2.1.0"
  },
  "optionalDependencies": {
    "serialport": "^10.2.2"
  },
  "devDependencies": {
    "@types/node": "18.7.1",
    "@typescript-eslint/eslint-plugin": "^5.58.0",
    "@typescript-eslint/parser": "^5.58.0",
    "@vitest/coverage-c8": "^0.32.0",
    "@vitest/ui": "^0.32.0",
    "eslint": "~8.15.0",
    "eslint-config-prettier": "8.1.0",
    "prettier": "^2.6.2",
    "typescript": "~5.1.3",
    "vite": "^4.3.9",
    "vitest": "^0.32.0"
  },
  "type": "commonjs"
}

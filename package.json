{
  "name": "ts-xbee-api",
  "description": "Node.js and Chrome communicate with XBee/ZigBee devices in API mode",
  "version": "4.0.0",
  "homepage": "https://github.com/flaviut/ts-xbee-api",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm run build && pnpm run type-check && pnpm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "dependencies": {
    "@serialport/parser-readline": "^13.0.0",
    "@serialport/stream": "^13.0.0",
    "real-cancellable-promise": "^1.2.3",
    "typed-emitter": "^2.1.0"
  },
  "optionalDependencies": {
    "serialport": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "22.19.17",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "eslint": "~10.2.1",
    "eslint-config-prettier": "10.1.8",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "type": "commonjs",
  "engines": {
    "node": ">=22"
  }
}
